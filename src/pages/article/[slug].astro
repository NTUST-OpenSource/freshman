---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { CATEGORIES } from '../../content.config';

export async function getStaticPaths() {
  const articles = await getCollection('articles', (e) => import.meta.env.DEV || !e.data.draft);
  const seen = new Set<string>();
  for (const a of articles) {
    if (seen.has(a.data.slug)) throw new Error(`[articles] slug 重複："${a.data.slug}"，路由會靜默互蓋`);
    seen.add(a.data.slug);
  }
  return articles.map((article) => ({ params: { slug: article.data.slug }, props: { article } }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const cat = CATEGORIES[article.data.category];
const updated = article.data.updated.toLocaleDateString('zh-TW');
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  dateModified: article.data.updated.toISOString(),
  inLanguage: 'zh-Hant',
  mainEntityOfPage: new URL(`/article/${article.data.slug}/`, Astro.site).toString(),
  // email 不進 LD：對 rich result 零貢獻、徒增收割面；mailto 管道在貢獻人卡
  ...(article.data.contributors.length
    ? { author: article.data.contributors.map((c) => ({ '@type': 'Person', name: c.name })) }
    : {}),
};
---

<Base
  title={article.data.title}
  description={article.data.description}
  noindex={article.data.noindex}
  ogType="article"
>
  {/* < 跳脫：內容含 </script> 也不會截斷資料塊 */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleLd).replace(/</g, '\\u003c')} />
  <div class={`article-layout cat-${article.data.category}`}>
    <article class="article">
      <header class="article__header" transition:name="article-head">
        <div class="article__eyebrow">
          <span class="chip chip--cat">{cat.label}</span>
          {article.data.draft && <span class="chip chip--draft">草稿</span>}
          <span class="article__meta">
            {updated} 更新
            {
              article.data.contributors.length > 0 && (
                <span class="contrib">
                  <button
                    class="contrib__btn"
                    id="contrib-btn"
                    type="button"
                    aria-expanded="false"
                    aria-label="貢獻人列表"
                  >
                    <span aria-hidden="true" />
                  </button>
                  <span class="contrib__card" id="contrib-card" hidden>
                    {article.data.contributors.map((c) => (
                      <a href={`mailto:${c.email}`}>
                        {c.name}
                        <span class="contrib__mail">{c.email}</span>
                      </a>
                    ))}
                  </span>
                </span>
              )
            }
          </span>
        </div>
        <h1 class="article__title">{article.data.title}</h1>
      </header>
      <div class="md">
        <Content />
      </div>
    </article>

    {
      toc.length > 0 && (
        <nav class="toc" aria-label="本頁目錄" transition:name="article-toc">
          <p class="toc__label">本頁目錄</p>
          <ol class="toc__line">
            {toc.map((h) => (
              <li class={`toc__item toc__item--d${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }
  </div>

  <script>
    // 內容一口氣逐塊淡入（不等捲動），與註腳 hover 預覽；掛 astro:page-load
    function initCascade() {
      const blocks = document.querySelectorAll<HTMLElement>('.md > *');
      let i = 0;
      for (const block of blocks) {
        if (block.classList.contains('md-cascade')) continue;
        block.classList.add('md-cascade');
        block.style.transitionDelay = `${Math.min(i * 35, 500)}ms`;
        i++;
      }
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          for (const block of blocks) block.classList.add('md-cascade--in');
          setTimeout(() => {
            for (const block of blocks) block.style.transitionDelay = '';
          }, 1100);
        }),
      );
    }

    function initFootnotePreview() {
      const refs = document.querySelectorAll<HTMLAnchorElement>('.md sup a[data-footnote-ref]');
      if (!refs.length) return;
      const fnPop = document.createElement('div');
      fnPop.className = 'fn-pop';
      fnPop.hidden = true;
      document.body.appendChild(fnPop);
      let fnTimer: number | undefined;

      const show = (ref: HTMLAnchorElement) => {
        clearTimeout(fnTimer);
        const id = decodeURIComponent(new URL(ref.href).hash.slice(1));
        const note = document.getElementById(id);
        if (!note) return;
        const clone = note.cloneNode(true) as HTMLElement;
        clone.querySelector('[data-footnote-backref]')?.remove();
        fnPop.innerHTML = clone.innerHTML;
        fnPop.hidden = false;
        const r = ref.getBoundingClientRect();
        const pw = fnPop.offsetWidth;
        const ph = fnPop.offsetHeight;
        const left = Math.min(Math.max(8, r.left + r.width / 2 - pw / 2), innerWidth - pw - 8);
        let top = r.top - ph - 10;
        if (top < 8) top = r.bottom + 10;
        fnPop.style.left = `${left}px`;
        fnPop.style.top = `${top}px`;
        requestAnimationFrame(() => fnPop.classList.add('fn-pop--show'));
      };
      const hide = () => {
        clearTimeout(fnTimer);
        fnTimer = window.setTimeout(() => {
          fnPop.classList.remove('fn-pop--show');
          fnPop.hidden = true;
        }, 130);
      };

      for (const ref of refs) {
        ref.addEventListener('pointerenter', () => show(ref));
        ref.addEventListener('pointerleave', hide);
        ref.addEventListener('focus', () => show(ref));
        ref.addEventListener('blur', hide);
      }
      fnPop.addEventListener('pointerenter', () => clearTimeout(fnTimer));
      fnPop.addEventListener('pointerleave', hide);
    }

    // 卡片開合放模組層、以 id 查當前元素：document 監聽只掛一次，
    // 不隨每篇文章導航累積（模組 script 由 router 去重，只執行一次）
    let contribCloseTimer: number | undefined;
    function closeContrib() {
      const card = document.getElementById('contrib-card');
      if (!card || card.hidden) return;
      card.classList.remove('contrib__card--open');
      document.getElementById('contrib-btn')?.setAttribute('aria-expanded', 'false');
      contribCloseTimer = window.setTimeout(() => (card.hidden = true), 170);
    }
    document.addEventListener('click', (e) => {
      const card = document.getElementById('contrib-card');
      if (card && !card.hidden && !card.contains(e.target as Node)) closeContrib();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeContrib();
    });

    function initContributors() {
      const btn = document.getElementById('contrib-btn');
      const card = document.getElementById('contrib-card');
      if (!btn || !card) return;
      const open = () => {
        clearTimeout(contribCloseTimer);
        card.hidden = false;
        requestAnimationFrame(() => card.classList.add('contrib__card--open'));
        btn.setAttribute('aria-expanded', 'true');
      };
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        btn.getAttribute('aria-expanded') === 'true' ? closeContrib() : open();
      });
    }

    document.addEventListener('astro:page-load', () => {
      if (!document.querySelector('.article-layout')) return;
      initCascade();
      initFootnotePreview();
      initContributors();
    });
  </script>
</Base>
