---
import Base from '../layouts/Base.astro';
import Calendar from '../components/Calendar.astro';
---

<Base chrome={false}>
  <div class="landing">
    <div class="landing__stage">
      <header class="landing__brand landing-rise" style="--d: 0">
        <img src="/logo.svg" alt="" width="34" height="35" />
        <span>台科新生懶人包</span>
      </header>

      <div class="landing__hero">
        <p class="landing__eyebrow landing-rise" style="--d: 1">開學前指南</p>
        <h1 class="landing__title landing-rise" style="--d: 2">
          天大地大<br />臺科大
        </h1>
        <p class="landing__desc landing-rise" style="--d: 3">
          沒有直屬怎麼辦，
        </p>
        <a class="landing__cta landing-rise" style="--d: 4" href="/article/start/">
          進入懶人包
          <span class="landing__cta-arrow" aria-hidden="true"></span>
        </a>
      </div>

      <div class="landing__route" aria-hidden="true">
        <svg viewBox="0 0 560 120" fill="none" preserveAspectRatio="none">
          <path
            class="landing__route-line"
            pathLength="1"
            d="M 10 96 C 130 96 150 26 280 26 S 430 96 550 96"
            stroke="var(--c-course)"
            stroke-width="5"
            stroke-linecap="round"
          ></path>
        </svg>
        <span class="landing__station" data-label="古亭" style="--pos: 14%; --s: 1"></span>
        <span class="landing__station" data-label="台電大樓" style="--pos: 50%; --s: 2"></span>
        <span class="landing__station landing__station--dest" data-label="公館" style="--pos: 88%; --s: 3"></span>
        <span class="landing__train" id="landing-train"></span>
      </div>
    </div>

    <Calendar />
  </div>

  <script>
    // 列車進站：古亭出發，30% 機率在台電大樓停靠，最後抵達公館（台科）
    const train = document.getElementById('landing-train');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (train && !reduced) {
      const ease = 'cubic-bezier(0.4, 0, 0.2, 1)';
      const ride = async () => {
        train.style.opacity = '1';
        await train.animate(
          [{ offsetDistance: '0%' }, { offsetDistance: '50%' }],
          { duration: 950, easing: ease, fill: 'forwards' },
        ).finished;
        if (Math.random() < 0.3) await new Promise((r) => setTimeout(r, 700));
        await train.animate(
          [{ offsetDistance: '50%' }, { offsetDistance: '88%' }],
          { duration: 800, easing: ease, fill: 'forwards' },
        ).finished;
        train.animate([{ opacity: 1 }, { opacity: 0 }], {
          duration: 450,
          delay: 300,
          fill: 'forwards',
        });
      };
      setTimeout(ride, 1750); // 等路線描線完成
    }
  </script>
</Base>
