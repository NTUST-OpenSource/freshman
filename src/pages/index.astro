---
import Base from '../layouts/Base.astro';
import Calendar from '../components/Calendar.astro';
---

<Base chrome={false}>
  <div class="landing">
    <div class="landing__stage">
      <header class="landing__brand landing-rise" style="--d: 0">
        <img src="/logo.svg" alt="" width="34" height="35" />
        <span>臺科新生懶人包</span>
      </header>

      <div class="landing__hero">
        <p class="landing__eyebrow landing-rise" style="--d: 1">開學前指南</p>
        <h1 class="landing__title landing-rise" style="--d: 2">
          天大地大<br />臺科大
        </h1>
        <p class="landing__desc landing-rise" style="--d: 3">
          沒有直屬，什麼都不懂，還可以撈撈嗎？
        </p>
        <a class="landing__cta landing-rise" style="--d: 4" href="/article/start/">
          進入懶人包
          <span class="landing__cta-arrow" aria-hidden="true"></span>
        </a>
      </div>

      <div class="landing__route" aria-hidden="true">
        <svg viewBox="0 0 560 120" fill="none" preserveAspectRatio="none">
          <path
            class="landing__route-line"
            pathLength="1"
            d="M 10 96 C 130 96 150 26 280 26 S 430 96 550 96"
            stroke="var(--c-course)"
            stroke-width="5"
            stroke-linecap="round"
          ></path>
        </svg>
        <span class="landing__station" data-label="中正紀念堂" style="offset-distance: 8%; --s: 1"></span>
        <span class="landing__station" data-label="古亭" style="offset-distance: 40%; --s: 2"></span>
        <span class="landing__station" data-label="台電大樓" style="offset-distance: 56%; --s: 3"></span>
        <span class="landing__station landing__station--dest" data-label="公館" style="offset-distance: 88%; --s: 4"></span>
        <span class="landing__train" id="landing-train"></span>
      </div>
    </div>

    <Calendar />
  </div>

  <script>
    // 列車無限循環：中正紀念堂 → 古亭 → 台電大樓 →（正常班到公館，台電大樓班直接駛離）→ 下一班
    function initTrain() {
      const train = document.getElementById('landing-train');
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!train || train.dataset.bound || reduced) return;
      train.dataset.bound = '1';

      const ease = 'cubic-bezier(0.4, 0, 0.2, 1)';
      const inbound = '0%';
      const cks = '8%';
      const guting = '40%';
      const taipower = '56%';
      const gongguan = '88%';
      const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
      const seg = (from: string, to: string, duration: number) =>
        train.animate([{ offsetDistance: from }, { offsetDistance: to }], {
          duration,
          easing: ease,
          fill: 'forwards',
        }).finished;

      // 導航離開時取消動畫並立旗；cancel 只殺得掉進行中的動畫，
      // 落在 sleep 期間的導航靠 aborted 旗標終止迴圈
      let aborted = false;
      document.addEventListener(
        'astro:before-swap',
        () => {
          aborted = true;
          train.getAnimations().forEach((a) => a.cancel());
        },
        { once: true },
      );

      (async () => {
        await sleep(1750); // 等路線描線完成
        try {
          while (!aborted && train.isConnected) {
            for (const a of train.getAnimations()) a.cancel();
            train.classList.remove('landing__train--taipower');
            train.style.offsetDistance = inbound;
            train.style.opacity = '1';
            await seg(inbound, cks, 320);
            await sleep(300); // 中正紀念堂停靠
            await seg(cks, guting, 720);
            await sleep(350); // 古亭停靠
            const goesToGongguan = Math.random() < 0.5;
            await seg(guting, taipower, 360);
            if (!goesToGongguan) train.classList.add('landing__train--taipower');
            await sleep(700); // 台電大樓停靠
            if (aborted) break;

            if (goesToGongguan) {
              await seg(taipower, gongguan, 720);
              await sleep(650); // 公館停靠
              if (aborted) break;
              await train.animate(
                [
                  { offsetDistance: gongguan, opacity: 1 },
                  { offsetDistance: '100%', opacity: 0 },
                ],
                { duration: 500, easing: ease, fill: 'forwards' },
              ).finished;
            } else {
              await train.animate(
                [
                  { offsetDistance: taipower, opacity: 1, offset: 0 },
                  { offsetDistance: '92%', opacity: 1, offset: 0.82 },
                  { offsetDistance: '100%', opacity: 0, offset: 1 },
                ],
                { duration: 990, easing: ease, fill: 'forwards' },
              ).finished;
            }
            await sleep(750); // 下一班發車間隔
          }
        } catch {
          /* 動畫被取消（頁面切換）即結束 */
        }
      })();
    }
    document.addEventListener('astro:page-load', initTrain);
  </script>
</Base>
