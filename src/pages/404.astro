---
import Base from '../layouts/Base.astro';
---

<Base title="找不到頁面" description="這個網址不存在或已被移動">
  <div class="not-found">
    <p class="not-found__code">404</p>
    <h1 class="not-found__title">這一站不存在</h1>
    <p class="not-found__desc">網址可能打錯了，或是內容已經搬家。</p>
    <a class="not-found__link" href="/article/start/">回到目錄</a>
  </div>
</Base>

<style is:global>
  .not-found {
    max-width: 76rem;
    margin-inline: auto;
    padding: clamp(4rem, 12vh, 8rem) 1.5rem;
    text-align: center;
  }

  .not-found__code {
    font-family: var(--font-mono);
    font-size: var(--text-tiny);
    letter-spacing: 0.35em;
    color: var(--brand);
  }

  .not-found__title {
    font-size: var(--text-h1);
    font-weight: 800;
    margin-top: 0.6rem;
  }

  .not-found__desc {
    color: var(--ink-soft);
    margin-top: 0.8rem;
  }

  .not-found__link {
    display: inline-block;
    margin-top: 1.8rem;
    font-weight: 700;
  }
</style>
