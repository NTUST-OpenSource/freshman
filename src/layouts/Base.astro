---
import { ClientRouter } from 'astro:transitions';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/markdown.css';
import '../styles/article.css';
import { DEPTS } from '../lib/depts.mjs';

interface Props {
  title?: string;
  description?: string;
  chrome?: boolean;
}

const { title, description = '提供臺科新生的開學前指南', chrome = true } = Astro.props;
const pageTitle = title ? `${title}｜臺科新生懶人包` : '臺科新生懶人包';
---

<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <ClientRouter />
    <script is:inline>
      document.documentElement.dataset.dept = localStorage.getItem('dept') || 'all';
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">跳到主要內容</a>
    {
      chrome && (
        <header class="site-header" transition:persist="site-header" transition:name="site-header">
          <nav class="site-header__inner" aria-label="主選單">
            <a class="brand" href="/">
              <img class="brand__logo" src="/logo.svg" alt="" width="30" height="31" />
              <span class="brand__text">臺科新生懶人包</span>
            </a>
            <div class="site-header__links">
              <a class="nav-pill" href="/article/start/">目錄</a>
              <a class="nav-pill" href="/article/contribute/">如何貢獻</a>
              <div class="dept-picker" id="dept-picker">
                <button
                  class="dept-picker__btn"
                  id="dept-btn"
                  type="button"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                >
                  <span id="dept-btn-label">全部</span>
                  <span class="dept-picker__chev" aria-hidden="true"></span>
                </button>
                <ul class="dept-picker__menu" id="dept-menu" role="listbox" aria-label="系別" hidden>
                  {DEPTS.map((d) => (
                    <li role="option" data-code={d.code} tabindex="-1">
                      {d.label}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </nav>
        </header>
      )
    }
    <main id="main">
      <slot />
    </main>
    {
      chrome && (
        <footer class="site-footer">
          <p>由臺科學長姐無償維護，歡迎分享，請勿營利</p>
        </footer>
      )
    }

    <script>
      // ClientRouter 導航後 module script 不會重跑，全部掛在 astro:page-load
      function initDeptPicker() {
        const deptBtn = document.getElementById('dept-btn');
        const deptMenu = document.getElementById('dept-menu');
        const deptLabel = document.getElementById('dept-btn-label');
        if (!deptBtn || !deptMenu || !deptLabel) return;
        if (deptBtn.dataset.bound) return; // header 為 persist 元素，避免重複綁定
        deptBtn.dataset.bound = '1';

        const options = [...deptMenu.querySelectorAll<HTMLElement>('[role="option"]')];
        const sync = () => {
          const code = document.documentElement.dataset.dept ?? 'all';
          for (const opt of options) {
            const selected = opt.dataset.code === code;
            opt.setAttribute('aria-selected', String(selected));
            if (selected) deptLabel.textContent = opt.textContent?.trim() ?? '全部';
          }
        };
        let closeTimer: number | undefined;
        const close = () => {
          deptMenu.classList.remove('dept-picker__menu--open');
          deptBtn.setAttribute('aria-expanded', 'false');
          closeTimer = window.setTimeout(() => (deptMenu.hidden = true), 170);
        };
        const open = () => {
          clearTimeout(closeTimer);
          deptMenu.hidden = false;
          requestAnimationFrame(() => deptMenu.classList.add('dept-picker__menu--open'));
          deptBtn.setAttribute('aria-expanded', 'true');
        };
        deptBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          deptBtn.getAttribute('aria-expanded') === 'true' ? close() : open();
        });
        for (const opt of options) {
          opt.addEventListener('click', () => {
            const code = opt.dataset.code ?? 'all';
            localStorage.setItem('dept', code);
            document.documentElement.dataset.dept = code;
            sync();
            close();
          });
        }
        document.addEventListener('click', (e) => {
          if (!deptMenu.hidden && !deptMenu.contains(e.target as Node)) close();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !deptMenu.hidden) close();
        });
        sync();
      }

      function initCodeCopy() {
        for (const pre of document.querySelectorAll('pre.astro-code')) {
          if (pre.querySelector('.code-copy')) continue;
          const btn = document.createElement('button');
          btn.className = 'code-copy';
          btn.type = 'button';
          btn.textContent = '複製';
          btn.addEventListener('click', async () => {
            await navigator.clipboard.writeText(pre.textContent ?? '');
            btn.textContent = '已複製';
            btn.classList.add('code-copy--done');
            setTimeout(() => {
              btn.textContent = '複製';
              btn.classList.remove('code-copy--done');
            }, 1400);
          });
          pre.appendChild(btn);
        }
      }

      function initYt() {
        for (const a of document.querySelectorAll('a.yt[data-yt-id]')) {
          a.addEventListener('click', (e) => {
            e.preventDefault();
            const id = (a as HTMLElement).dataset.ytId;
            const iframe = document.createElement('iframe');
            iframe.className = 'yt__iframe';
            iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
            iframe.allow = 'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture';
            iframe.allowFullscreen = true;
            iframe.title = a.querySelector('.yt__title')?.textContent ?? 'YouTube';
            a.replaceWith(iframe);
          }, { once: true });
        }
      }

      async function initMermaid() {
        if (!document.querySelector('pre.mermaid')) return;
        try {
          const { default: mermaid } = await import('mermaid');
          mermaid.initialize({ startOnLoad: false, theme: 'neutral', fontFamily: 'inherit' });
          await mermaid.run({ querySelector: 'pre.mermaid', suppressErrors: false });
        } catch (err) {
          console.error('[mermaid] 渲染失敗：', err);
        }
      }

      document.addEventListener('astro:page-load', () => {
        initDeptPicker();
        initCodeCopy();
        initYt();
        initMermaid();
      });
    </script>
  </body>
</html>
